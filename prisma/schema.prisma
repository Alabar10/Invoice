// Prisma schema — invoice persistence
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Single reusable company profile (one row, id = "default").
// Auto-fills the business fields on every new receipt.
model BusinessProfile {
  id              String   @id @default("default")
  businessName    String   @default("")
  businessTaxId   String   @default("")
  businessAddress String   @default("")
  businessPhone   String   @default("")
  logoUrl         String   @default("")
  updatedAt       DateTime @updatedAt
}

model Receipt {
  id             String   @id @default(cuid())
  documentType   String
  documentNumber String   @unique
  date           String
  time           String   @default("")
  customerName   String   @default("")
  subtotal       Float    @default(0)
  vatAmount      Float    @default(0)
  total          Float    @default(0)
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
}
